# Build: docker build -f Dockerfile.loadtest -t kv-loadtest .
FROM --platform=linux/amd64 golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/loadtest ./cmd/loadtest

FROM --platform=linux/amd64 alpine:3.19
RUN adduser -D -u 65532 app
USER 65532:65532
COPY --from=build /out/loadtest /loadtest
ENTRYPOINT ["/loadtest"]
